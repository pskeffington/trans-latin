{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pskeffington/trans-latin/schemas/latin_translation_unit.schema.json",
  "title": "Trans-Latin Translation Unit",
  "type": "object",
  "required": [
    "unit_id",
    "collection_id",
    "witness_id",
    "line_reference",
    "source_latin",
    "normalized_latin",
    "tokens",
    "literal_translation",
    "interpretive_translation",
    "translation_status",
    "audit"
  ],
  "properties": {
    "unit_id": {
      "type": "string",
      "pattern": "^TLA-[A-Z0-9]+-[A-Z0-9]+-[A-Z0-9]+-[A-Z0-9]+$"
    },
    "collection_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+$"
    },
    "witness_id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+$"
    },
    "line_reference": {
      "type": "string",
      "minLength": 1
    },
    "source_latin": {
      "type": "string",
      "minLength": 1
    },
    "normalized_latin": {
      "type": "string",
      "minLength": 1
    },
    "tokens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["surface", "lemma", "pos"],
        "properties": {
          "surface": {"type": "string", "minLength": 1},
          "lemma": {"type": "string"},
          "pos": {"type": "string"},
          "morphology": {"type": "string"},
          "gloss": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "word_by_word_gloss": {
      "type": "string"
    },
    "literal_translation": {
      "type": "string",
      "minLength": 1
    },
    "interpretive_translation": {
      "type": "string",
      "minLength": 1
    },
    "uncertainty_flags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "apparatus_links": {
      "type": "array",
      "items": {"type": "string"}
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "translation_status": {
      "type": "string",
      "enum": ["draft", "machine_checked", "human_reviewed", "approved", "rejected", "superseded"]
    },
    "reviewer": {
      "type": ["string", "null"]
    },
    "audit": {
      "type": "object",
      "required": [
        "pipeline_version",
        "checksum_sha256",
        "method",
        "created_at_utc",
        "validation_status"
      ],
      "properties": {
        "pipeline_version": {"type": "string", "minLength": 1},
        "checksum_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "method": {"type": "string", "enum": ["manual", "llm_assisted", "rule_based", "hybrid"]},
        "created_at_utc": {"type": "string", "format": "date-time"},
        "updated_at_utc": {"type": "string", "format": "date-time"},
        "validation_status": {"type": "string", "enum": ["pending", "passed", "failed"]},
        "source_reference": {"type": "string"},
        "source_rights_status": {"type": "string"},
        "normalization_policy": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
