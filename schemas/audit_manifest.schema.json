{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pskeffington/trans-latin/schemas/audit_manifest.schema.json",
  "title": "Trans-Latin Audit Manifest",
  "type": "object",
  "required": ["manifest_id", "created_at_utc", "pipeline_version", "artifacts"],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^TLA-MANIFEST-[0-9]{4}-[0-9]{6}$"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "pipeline_version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "artifact_type", "checksum_sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "translation_record",
              "latin_translation_unit",
              "processing_handoff",
              "audit_event",
              "schema",
              "policy_document",
              "qa_script",
              "workflow",
              "makefile",
              "other"
            ]
          },
          "object_id": {
            "type": "string"
          },
          "checksum_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
