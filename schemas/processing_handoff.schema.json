{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pskeffington/trans-latin/schemas/processing_handoff.schema.json",
  "title": "Trans-Latin Processing Handoff",
  "type": "object",
  "required": [
    "handoff_id",
    "unit_id",
    "processor",
    "source_payload",
    "accepted_fields",
    "rejected_fields",
    "created_at_utc",
    "audit"
  ],
  "properties": {
    "handoff_id": {
      "type": "string",
      "pattern": "^TLA-HANDOFF-[0-9]{4}-[0-9]{6}$"
    },
    "unit_id": {
      "type": "string",
      "pattern": "^TLA-[A-Z0-9]+-[A-Z0-9]+-[A-Z0-9]+-[A-Z0-9]+$"
    },
    "processor": {
      "type": "object",
      "required": ["repo", "name", "version", "commit", "config"],
      "properties": {
        "repo": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "minLength": 7},
        "config": {"type": "object"}
      },
      "additionalProperties": false
    },
    "source_payload": {
      "type": "object",
      "required": ["source_latin", "normalized_latin", "tokens"],
      "properties": {
        "source_latin": {"type": "string", "minLength": 1},
        "normalized_latin": {"type": "string", "minLength": 1},
        "tokens": {
          "type": "array",
          "items": {"type": "object"}
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "accepted_fields": {
      "type": "array",
      "items": {"type": "string"}
    },
    "rejected_fields": {
      "type": "array",
      "items": {"type": "string"}
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": ["string", "null"]
    },
    "review_status": {
      "type": "string",
      "enum": ["pending", "accepted", "partially_accepted", "rejected", "superseded"]
    },
    "audit": {
      "type": "object",
      "required": ["payload_checksum_sha256", "handoff_checksum_sha256", "pipeline_version"],
      "properties": {
        "payload_checksum_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "handoff_checksum_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "pipeline_version": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
